# Copy to .env locally (never commit secrets). Flask does not load .env by default;
# export these variables in your shell, or install python-dotenv for development.

# SQL Server hosting dbo.catalog_data
CATALOG_SQL_SERVER=localhost
CATALOG_SQL_DATABASE=ReportCatalog
# Windows default; on Linux/macOS install Microsoft ODBC Driver 18 and adjust.
CATALOG_ODBC_DRIVER={ODBC Driver 17 for SQL Server}
# Optional: SQL authentication (if unset, Trusted_Connection is used)
# CATALOG_SQL_USER=
# CATALOG_SQL_PASSWORD=

# Must match dbo.catalog_data.[Report Type] for rows loaded from your web dashboards ETL branch
CATALOG_WEB_PLATFORM_DASHBOARD_TYPE=Web Dashboard

# Must match dbo.catalog_data.[Report Type] for the SSRS «program dashboard» category (see catalogquery.sql CASE)
CATALOG_SSRS_PROGRAM_DASHBOARD_TYPE=SSRS Program Dashboards
